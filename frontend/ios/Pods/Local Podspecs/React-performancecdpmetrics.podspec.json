{
  "name": "React-performancecdpmetrics",
  "version": "0.83.4",
  "summary": "Module for reporting React Native performance live metrics to the debugger",
  "homepage": "https://reactnative.dev/",
  "license": "MIT",
  "authors": "Meta Platforms, Inc. and its affiliates",
  "platforms": {
    "ios": "15.1"
  },
  "source": {
    "git": "https://github.com/facebook/react-native.git",
    "tag": "v0.83.4"
  },
  "source_files": "**/*.h",
  "header_dir": "react/performance/cdpmetrics",
  "exclude_files": "tests",
  "pod_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "HEADER_SEARCH_PATHS": "\"${PODS_ROOT}/React-runtimeexecutor\" \"${PODS_ROOT}/React-runtimeexecutor/platform/ios\""
  },
  "dependencies": {
    "React-runtimeexecutor": [],
    "React-jsi": [],
    "React-performancetimeline": [],
    "React-timing": [],
    "ReactNativeDependencies": [],
    "React-Core-prebuilt": [],
    "hermes-engine": []
  }
}
