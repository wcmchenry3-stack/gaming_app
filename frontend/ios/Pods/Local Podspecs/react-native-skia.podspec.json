{
  "name": "react-native-skia",
  "version": "2.4.18",
  "summary": "High-performance React Native Graphics using Skia",
  "description": "@shopify/react-native-skia",
  "homepage": "https://github.com/shopify/react-native-skia",
  "license": {
    "type": "MIT",
    "file": "LICENSE.md"
  },
  "authors": {
    "Christian Falch": "christian.falch@gmail.com",
    "William Candillon": "wcandillon@gmail.com"
  },
  "platforms": {
    "ios": "14.0",
    "tvos": "13.0",
    "osx": "11"
  },
  "source": {
    "git": "https://github.com/shopify/react-native-skia/react-native-skia.git",
    "tag": "2.4.18"
  },
  "requires_arc": true,
  "pod_target_xcconfig": {
    "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) SK_METAL=1 SK_GANESH=1 SK_IMAGE_READ_PIXELS_DISABLE_LEGACY_API=1 SK_DISABLE_LEGACY_SHAPER_FACTORY=1",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "DEFINES_MODULE": "YES",
    "HEADER_SEARCH_PATHS": "\"$(PODS_TARGET_SRCROOT)/cpp/\"/** \"$(PODS_TARGET_SRCROOT)/cpp\" \"$(PODS_TARGET_SRCROOT)/cpp/jsi2\" \"$(PODS_TARGET_SRCROOT)/cpp/rnwgpu\" \"$(PODS_TARGET_SRCROOT)/cpp/rnwgpu/api\" \"$(PODS_TARGET_SRCROOT)/cpp/rnwgpu/api/descriptors\" \"$(PODS_TARGET_SRCROOT)/cpp/rnwgpu/async\" \"$(PODS_TARGET_SRCROOT)/cpp/dawn/include\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -DRCT_NEW_ARCH_ENABLED=1 ",
    "OTHER_SWIFT_FLAGS": "$(inherited) -DRCT_NEW_ARCH_ENABLED"
  },
  "frameworks": [
    "MetalKit",
    "AVFoundation",
    "AVKit",
    "CoreMedia"
  ],
  "ios": {
    "vendored_frameworks": [
      "libs/apple/ios/libskia.xcframework",
      "libs/apple/ios/libsvg.xcframework",
      "libs/apple/ios/libskshaper.xcframework",
      "libs/apple/ios/libskparagraph.xcframework",
      "libs/apple/ios/libskunicode_core.xcframework",
      "libs/apple/ios/libskunicode_libgrapheme.xcframework",
      "libs/apple/ios/libskottie.xcframework",
      "libs/apple/ios/libsksg.xcframework"
    ]
  },
  "osx": {
    "vendored_frameworks": [
      "libs/apple/macos/libskia.xcframework",
      "libs/apple/macos/libsvg.xcframework",
      "libs/apple/macos/libskshaper.xcframework",
      "libs/apple/macos/libskparagraph.xcframework",
      "libs/apple/macos/libskunicode_core.xcframework",
      "libs/apple/macos/libskunicode_libgrapheme.xcframework",
      "libs/apple/macos/libskottie.xcframework",
      "libs/apple/macos/libsksg.xcframework"
    ]
  },
  "tvos": {
    "vendored_frameworks": [
      "libs/apple/tvos/libskia.xcframework",
      "libs/apple/tvos/libsvg.xcframework",
      "libs/apple/tvos/libskshaper.xcframework",
      "libs/apple/tvos/libskparagraph.xcframework",
      "libs/apple/tvos/libskunicode_core.xcframework",
      "libs/apple/tvos/libskunicode_libgrapheme.xcframework",
      "libs/apple/tvos/libskottie.xcframework",
      "libs/apple/tvos/libsksg.xcframework"
    ]
  },
  "source_files": [
    "apple/**/*.{h,c,cc,cpp,m,mm,swift}",
    "cpp/**/*.{h,cpp}"
  ],
  "exclude_files": [
    "cpp/rnskia/RNDawnContext.h",
    "cpp/rnskia/RNDawnUtils.h",
    "cpp/rnskia/RNDawnWindowContext.h",
    "cpp/rnskia/RNDawnWindowContext.cpp",
    "cpp/rnskia/RNImageProvider.h",
    "cpp/rnwgpu/**/*.{h,cpp}"
  ],
  "compiler_flags": "-DRCT_NEW_ARCH_ENABLED=1",
  "dependencies": {
    "React-Core": [],
    "React-RCTFabric": [],
    "ReactCodegen": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/bridging": [],
    "ReactCommon/turbomodule/core": [],
    "React-NativeModulesApple": [],
    "Yoga": [],
    "React-Fabric": [],
    "React-graphics": [],
    "React-utils": [],
    "React-featureflags": [],
    "React-debug": [],
    "React-ImageManager": [],
    "React-rendererdebug": [],
    "React-jsi": [],
    "React-renderercss": [],
    "hermes-engine": [],
    "ReactNativeDependencies": [],
    "React-Core-prebuilt": [],
    "React": [],
    "React-callinvoker": []
  }
}
