{
  "name": "ExpoModulesJSI",
  "version": "55.0.18",
  "summary": "The core of Expo Modules architecture",
  "description": "The core of Expo Modules architecture",
  "license": "MIT",
  "authors": "650 Industries, Inc.",
  "homepage": "https://github.com/expo/expo/tree/main/packages/expo-modules-core",
  "platforms": {
    "ios": "15.1",
    "osx": "11.0",
    "tvos": "15.1"
  },
  "swift_versions": "6.0",
  "source": {
    "git": "https://github.com/expo/expo.git"
  },
  "static_framework": true,
  "header_dir": "ExpoModulesJSI",
  "pod_target_xcconfig": {
    "USE_HEADERMAP": "YES",
    "DEFINES_MODULE": "YES",
    "HEADER_SEARCH_PATHS": ""
  },
  "dependencies": {
    "hermes-engine": [],
    "React-Core": [],
    "ReactCommon": [],
    "React-runtimescheduler": []
  },
  "source_files": [
    "ios/JSI/**/*.{h,m,mm,swift,cpp}",
    "common/cpp/JSI/**/*.{h,cpp}"
  ],
  "exclude_files": [
    "ios/JSI/Tests"
  ],
  "private_header_files": [
    "ios/JSI/**/*+Private.h",
    "ios/JSI/**/Swift.h"
  ],
  "testspecs": [
    {
      "name": "Tests",
      "test_type": "unit",
      "source_files": "ios/JSI/Tests/**/*.{m,swift}"
    }
  ],
  "swift_version": "6.0"
}
