{
  "name": "React-jsinspector",
  "version": "0.83.4",
  "summary": "React Native subsystem for modern debugging over the Chrome DevTools Protocol (CDP)",
  "homepage": "https://reactnative.dev/",
  "license": "MIT",
  "authors": "Meta Platforms, Inc. and its affiliates",
  "platforms": {
    "ios": "15.1"
  },
  "source": {
    "git": "https://github.com/facebook/react-native.git",
    "tag": "v0.83.4"
  },
  "source_files": "*.h",
  "header_dir": "jsinspector-modern",
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"${PODS_ROOT}/React-oscompat\" \"${PODS_ROOT}/React-runtimeexecutor\" \"${PODS_ROOT}/React-runtimeexecutor/platform/ios\" \"${PODS_ROOT}/React-jsinspectorcdp\" \"${PODS_ROOT}/React-jsinspectornetwork\" \"${PODS_ROOT}/React-jsinspectortracing\" \"${PODS_ROOT}/React-oscompat\" \"${PODS_ROOT}/React-utils\" \"${PODS_ROOT}/React-utils/react/utils/platform/ios\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "DEFINES_MODULE": "YES"
  },
  "dependencies": {
    "React-oscompat": [],
    "React-featureflags": [],
    "React-runtimeexecutor": [],
    "React-jsi": [],
    "React-jsinspectorcdp": [],
    "React-jsinspectornetwork": [],
    "React-jsinspectortracing": [],
    "React-perflogger": ["0.83.4"],
    "React-utils": [],
    "hermes-engine": [],
    "ReactNativeDependencies": [],
    "React-Core-prebuilt": []
  }
}
