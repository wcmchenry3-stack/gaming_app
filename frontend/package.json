{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "translate": "node scripts/translate.js",
    "check-i18n": "node scripts/check-i18n-strings.js"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|i18next|react-i18next|i18next-resources-to-backend)"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@types/matter-js": "^0.20.2",
    "expo": "~55.0.8",
    "expo-localization": "^55.0.9",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.10.5",
    "i18next-resources-to-backend": "^1.2.1",
    "matter-js": "^0.20.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.2",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "prettier": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
